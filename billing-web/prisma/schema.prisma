generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String               @id @default(uuid())
  name               String
  domain             String               @unique
  dbConnectionString String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  status             String               @default("ACTIVE")
  address            String?
  landmark           String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  contactPerson      String?
  email              String?              @unique
  gstin              String?
  phone              String?              @unique
  subscriptionPlan   String               @default("FREE")
  menuTheme          String?
  currency           String               @default("INR")
  logoUrl            String?
  timezone           String               @default("Asia/Kolkata")
  website            String?
  websiteSlug        String?              @unique
  aadharCardUrl      String?
  version            Int                  @default(0)
  primaryColor       String?
  fontFamily         String?
  latitude           Float?
  longitude          Float?
  tagline            String?
  aboutText          String?
  coverImageUrl      String?
  shopFrontImageUrl  String?
  ownerImageUrl      String?
  businessHours      String?
  // Service-business pivot (Cafe/Laundry/Salon). Nullable and unset by default so existing
  // general/medical-store-style tenants keep today's generic Product/POS UI unchanged — this only
  // takes effect for tenants that explicitly opt in (new signups, or existing ones via Settings).
  businessType       String?
  customers          Customer[]
  discounts          Discount[]
  employees          Employee[]
  expenses           Expense[]
  notifications      Notification[]
  orderRequests      OrderRequest[]
  products           Product[]
  roles              Role[]
  units              Unit[]
  shop               Shop?
  tables             Table[]
  transactions       Transaction[]
  users              User[]
  subscriptions      TenantSubscription[]
  invoices           Invoice[]
  auditLogs          AuditLog[]
  websiteSettings    Website?
  websiteVisits      WebsiteVisit[]
  contactLeads       ContactLead[]
  favoritedBy        CustomerFavorite[]
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, name])
}

// Tenant-managed master list of base units (PIECE, KG, LITRE, ...) offered as a dropdown when
// adding a product. Product.unit stays a plain string (not a FK) so deleting a Unit here never
// invalidates existing products — it just stops appearing as a pickable option going forward.
model Unit {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  password          String
  name              String
  role              String        @default("ADMIN")
  tenantId          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenantRoleId      String?
  phone             String?
  jobTitle          String?
  profilePictureUrl String?
  tokenVersion      Int           @default(0)
  transactions      Transaction[]
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantRole        Role?         @relation(fields: [tenantRoleId], references: [id])
  auditLogs         AuditLog[]
}

model Product {
  id                String            @id @default(uuid())
  name              String
  barcode           String?
  purchasePrice     Float             @default(0)
  mrp               Float             @default(0)
  salePrice         Float             @default(0)
  stock             Float             @default(0)
  expiryDate        DateTime?
  manufacturingDate DateTime?
  batchNumber       String?
  category          String?
  minStockThreshold Float             @default(10)
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  unit              String            @default("PIECE")
  allowDecimal      Boolean           @default(false)
  productType       String            @default("SIMPLE")
  description       String?
  imageUrl          String?
  // Business-type-specific catalog fields (Cafe/Laundry/Salon). Nullable, ignored by every
  // existing productType/business flow.
  durationMinutes   Int?              // Salon: service duration. Cafe: doubles as prep time (minutes).
  garmentType       String?           // Laundry: distinct from `category` (Service Category)
  // Cafe GST/menu fields. Nullable — a null gstRate means "no tax", not "inherit tenant rate";
  // Shop.defaultTaxRate remains the tenant-level fallback used only by the online-order path today.
  gstRate           Float?
  gstInclusive      Boolean           @default(false)
  foodType          String?           // VEG | NON_VEG | VEGAN | JAIN
  isAvailable       Boolean           @default(true)
  isFeatured        Boolean           @default(false)
  addOns            ProductAddOn[]
  comboComponents   ComboItem[]       @relation("ComboItems")
  usedInCombos      ComboItem[]       @relation("ComboComponents")
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches           ProductBatch[]
  serials           ProductSerial[]
  variants          ProductVariant[]
  transactionItems  TransactionItem[]

  @@unique([tenantId, barcode])
}

model ProductVariant {
  id            String      @id @default(uuid())
  productId     String
  name          String
  barcode       String?
  purchasePrice Float
  mrp           Float
  salePrice     Float
  stock         Float       @default(0)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  comboUsages   ComboItem[]
}

// Cafe: add-ons belong to one specific product (e.g. "Extra Shot +15" on a Cappuccino), not a
// tenant-wide list — a coffee's add-ons rarely make sense on a sandwich.
model ProductAddOn {
  id        String  @id @default(uuid())
  productId String
  name      String
  price     Float   @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Cafe: links a Product with productType "COMBO" to the regular Products it bundles. The combo
// sells at its own flat price (like any other Product.salePrice) — this table is for
// receipt/kitchen display only, not per-component pricing or stock deduction (component-level
// stock/recipe deduction is deferred, see "Recipe-ready architecture" in the phase 1 spec).
// componentVariantId optionally pins a specific size (e.g. "Cold Coffee — Small") rather than the
// whole product generically. onDelete: SetNull (not Restrict) because updateProduct deletes and
// recreates all of a product's ProductVariant rows on every edit — a hard FK would break editing
// any product used inside a combo; SetNull instead just degrades the reference to "whole product,
// no size" if that ever happens.
model ComboItem {
  id                 String          @id @default(uuid())
  comboId            String
  componentId        String
  componentVariantId String?
  quantity           Int             @default(1)
  combo              Product         @relation("ComboItems", fields: [comboId], references: [id], onDelete: Cascade)
  component          Product         @relation("ComboComponents", fields: [componentId], references: [id])
  componentVariant   ProductVariant? @relation(fields: [componentVariantId], references: [id], onDelete: SetNull)

  @@index([comboId])
  @@index([componentVariantId])
}

model ProductBatch {
  id                String    @id @default(uuid())
  productId         String
  batchNumber       String
  manufacturingDate DateTime?
  expiryDate        DateTime?
  stock             Float     @default(0)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSerial {
  id             String    @id @default(uuid())
  productId      String
  serialNumber   String
  status         String    @default("AVAILABLE")
  purchaseDate   DateTime?
  warrantyMonths Int?
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, serialNumber])
}

model CustomerAccount {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  name             String
  phone            String?
  tokenVersion     Int            @default(0)
  fcmToken         String?
  // Forgot/reset password: a random token + expiry, cleared on successful reset. Not JWT-based —
  // this is a separate single-use secret emailed to the customer, distinct from the login session token.
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  customers        Customer[]
  orderRequests    OrderRequest[]
  notifications    Notification[]
  favorites        CustomerFavorite[]
  addresses        CustomerAddress[]
}

// Saved delivery addresses for a customer's profile — future-ready for when DELIVERY orderType
// ships (see OrderRequest.orderType), not yet selectable during checkout since order routing/
// fulfillment for delivery doesn't exist yet.
model CustomerAddress {
  id                String          @id @default(uuid())
  customerAccountId String
  label             String?
  fullAddress       String
  landmark          String?
  city              String?
  state             String?
  postalCode        String?
  latitude          Float?
  longitude         Float?
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@index([customerAccountId])
}

// Favourited cafes for the mobile app's "Favourite Cafes" list (a per-cafe favourite, not
// per-product — matches what the mobile Profile screen already has a placeholder tile for).
model CustomerFavorite {
  id                String          @id @default(uuid())
  customerAccountId String
  tenantId          String
  createdAt         DateTime        @default(now())
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([customerAccountId, tenantId])
  @@index([tenantId])
}

model Customer {
  id                String           @id @default(uuid())
  name              String
  phone             String?
  email             String?
  address           String?
  loyaltyPoints     Int              @default(0)
  totalSpent        Float            @default(0)
  lastPurchaseDate  DateTime?
  createdDate       DateTime         @default(now())
  tenantId          String
  customerAccountId String?
  customerAccount   CustomerAccount? @relation(fields: [customerAccountId], references: [id])
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderRequests     OrderRequest[]
  notifications     Notification[]

  @@index([tenantId])
  @@index([customerAccountId])
}

// QR ordering: one row per physical table. The QR code encodes `qrToken`, not the raw label, so
// renaming/renumbering a table (or regenerating a lost/damaged QR) never invalidates other tables'
// printed codes and never changes the URL a still-valid QR points to.
model Table {
  id            String         @id @default(uuid())
  tenantId      String
  label         String
  qrToken       String         @unique @default(uuid())
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderRequests OrderRequest[]

  @@unique([tenantId, label])
  @@index([tenantId])
}

model OrderRequest {
  id                String             @id @default(uuid())
  // PENDING | ACCEPTED | PREPARING | READY | COMPLETED | REJECTED | CANCELLED. Kept as a plain
  // String (matching Transaction.status/orderType elsewhere in this schema) rather than a Prisma
  // enum so new stages can be introduced without a migration; only PENDING/COMPLETED/REJECTED are
  // written by any code path as of this migration — ACCEPTED/PREPARING/READY/CANCELLED are reserved
  // for the Cafe Dashboard + Kitchen Queue phases.
  status            String             @default("PENDING")
  notes             String?
  totalAmount       Float              @default(0)
  taxAmount         Float              @default(0)
  netAmount         Float              @default(0)
  // Auto-applied Discount (no code — a customer-entered coupon-code flow doesn't exist yet), snapshotted
  // at order time same as comboComponents below, so a later Discount edit never rewrites past orders.
  discountAmount    Float              @default(0)
  discountLabel     String?
  tenantId          String
  // Nullable to support guest checkout (no CustomerAccount). Guest orders instead populate
  // guestName/guestPhone directly; logged-in orders keep using customerAccount as before.
  customerAccountId String?
  customerId        String?
  transactionId     String?
  tableId           String?
  orderType         String?            // DINE_IN | TAKE_AWAY | DELIVERY, mirrors Transaction.orderType
  guestName         String?
  guestPhone        String?
  // Client-generated key for this checkout attempt (retries of the same attempt reuse it) — lets
  // createCustomerOrder() detect and return the original order instead of creating a duplicate.
  idempotencyKey    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  customerAccount   CustomerAccount?   @relation(fields: [customerAccountId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table             Table?             @relation(fields: [tableId], references: [id])
  items             OrderRequestItem[]

  @@index([tenantId, status])
  @@index([customerAccountId])
  @@index([tableId])
  @@unique([customerAccountId, idempotencyKey])
}

model OrderRequestItem {
  id             String       @id @default(uuid())
  orderRequestId String
  productId      String
  name           String
  barcode        String?
  salePrice      Float
  quantity       Float
  itemTotal      Float
  // Cafe: snapshot of what a COMBO item contained at order time (name + variant name + qty), e.g.
  // [{"name":"Cold Coffee","variantName":"Small","quantity":1}]. Snapshotted, not a live relation,
  // so a later ComboItem recipe edit never rewrites a past order — same pattern as
  // TransactionItem.selectedAddOns/comboComponents below.
  comboComponents Json?
  orderRequest   OrderRequest @relation(fields: [orderRequestId], references: [id], onDelete: Cascade)
}

model Notification {
  id       String  @id @default(uuid())
  type     String  @default("ORDER_STATUS") // ORDER_STATUS, GENERAL, PROMOTION
  title    String
  message  String
  isRead   Boolean @default(false)
  orderId  String?
  metadata String? // JSON string for extra data

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerAccountId, isRead])
  @@index([tenantId, createdAt])
}

model Expense {
  id         String   @id @default(uuid())
  name       String
  category   String   @default("OTHER")
  amount     Float
  date       DateTime @default(now())
  notes      String?
  receiptUrl String?
  tenantId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
}

model Discount {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  code               String?   @unique
  discountPercentage Float
  applicableCategory String?
  minimumQuantity    Int       @default(1)
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean   @default(true)
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Employee {
  id                 String   @id @default(uuid())
  name               String
  email              String?
  phone              String?
  password           String?
  role               String   @default("CASHIER")
  isActive           Boolean  @default(true)
  monthlySalesTarget Float    @default(0)
  createdDate        DateTime @default(now())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Shop {
  id             String  @id @default(uuid())
  name           String?
  addressLine1   String?
  addressLine2   String?
  phoneNumber    String?
  upiId          String?
  footerText     String?
  defaultTaxRate Float   @default(0)
  tenantId       String  @unique
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                    String               @id @default(uuid())
  tenantId              String
  userId                String
  status                String               @default("COMPLETED")
  totalAmount           Float
  discount              Float                @default(0)
  netAmount             Float
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  amountReceived        Float?
  changeAmount          Float?
  customerId            String?
  customerName          String?
  customerPhone         String?
  discountType          String               @default("PERCENTAGE")
  notes                 String?
  paymentMethod         String?
  taxAmount             Float                @default(0)
  couponCode            String?
  couponDiscountAmount  Float                @default(0)
  loyaltyPointsRedeemed Int                  @default(0)
  loyaltyDiscountAmount Float                @default(0)
  loyaltyPointsEarned   Int                  @default(0)
  // Cafe: table + fulfillment type. Nullable — irrelevant to every other business type.
  tableNumber           String?
  orderType             String?              // DINE_IN | TAKE_AWAY | DELIVERY
  // Cafe Kitchen Queue: independent of `status` (payment/billing) — a POS sale is already paid
  // the moment it's created, but the kitchen still needs to prepare it. Null means "never sent to
  // kitchen" (a non-food sale, or a business type with no kitchen concept). PREPARING | READY | SERVED.
  kitchenStatus         String?
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User                 @relation(fields: [userId], references: [id])
  items                 TransactionItem[]
  payments              TransactionPayment[]
}

model TransactionPayment {
  id            String      @id @default(uuid())
  transactionId String
  method        String
  amount        Float
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model TransactionItem {
  id             String      @id @default(uuid())
  transactionId  String
  productId      String
  name           String
  barcode        String
  purchasePrice  Float
  mrp            Float
  salePrice      Float
  quantity       Float
  itemTotal      Float
  discountAmount Float       @default(0)
  productType    String?
  batchId        String?
  serialId       String?
  variantId      String?
  // Cafe: snapshot of selected add-ons at sale time (name + price), e.g. [{"name":"Extra Shot","price":15}].
  // Snapshotted rather than a live relation so a later ProductAddOn price/name change never rewrites history.
  selectedAddOns Json?
  // Cafe: snapshot of what a COMBO item contained at sale time (name + variant name + qty), e.g.
  // [{"name":"Cold Coffee","variantName":"Small","quantity":1}]. Same reasoning as selectedAddOns
  // above — a later ComboItem recipe edit must never rewrite a past sale's receipt/kitchen ticket.
  comboComponents Json?
  product        Product     @relation(fields: [productId], references: [id])
  transaction    Transaction @relation(fields: [transactionId], references: [id])
}

model SubscriptionPlan {
  id              String               @id @default(uuid())
  name            String
  description     String?
  amount          Float
  currency        String               @default("INR")
  interval        String // "MONTHLY" or "YEARLY"
  razorpayPlanId  String?
  trialDays       Int                  @default(0)
  maxProducts     Int                  @default(-1)
  maxUsers        Int                  @default(-1)
  maxTransactions Int                  @default(-1)
  // QR ordering tables (-1 = unlimited). Business-capability limit, unlike maxProducts/
  // maxTransactions which are being phased toward always-unlimited — see maxTables comment
  // on plan philosophy in lib/subscription.ts.
  maxTables       Int                  @default(-1)
  // Website theme ids this plan may select (lib/website/themeDefinitions.ts). Empty array means "all
  // themes allowed" — this is a whitelist, not a count, so it can't reuse the -1-means-unlimited
  // convention the numeric limits use.
  allowedThemes   String[]             @default([])
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  subscriptions   TenantSubscription[]
}

model TenantSubscription {
  id                     String    @id @default(uuid())
  tenantId               String
  planId                 String
  status                 String // "ACTIVE", "TRIAL", "CANCELLED", "PAST_DUE", "EXPIRED", "UNPAID"
  razorpaySubscriptionId String?   @unique
  startDate              DateTime  @default(now())
  endDate                DateTime
  trialStartDate         DateTime?
  trialEndDate           DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  canceledAt             DateTime?
  endedAt                DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
}

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  discountType   String // "PERCENTAGE" or "FIXED"
  discountValue  Float
  expiryDate     DateTime?
  maxRedemptions Int?
  redemptions    Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]
}

model Invoice {
  id                    String    @id @default(uuid())
  tenantId              String
  subscriptionId        String?
  invoiceNumber         String    @unique
  amount                Float
  discountAmount        Float     @default(0)
  netAmount             Float
  currency              String    @default("INR")
  status                String // "PAID", "PENDING", "FAILED"
  billingDate           DateTime  @default(now())
  dueDate               DateTime?
  paidAt                DateTime?
  razorpayPaymentId     String?
  razorpayOrderId       String?
  razorpaySignature     String?
  couponId              String?
  pdfUrl                String?
  failedPaymentAttempts Int       @default(0)
  nextRetryDate         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription TenantSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  coupon       Coupon?             @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Website {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  theme         String   @default("modern-restaurant")
  
  // Appearance (Colors, Fonts, Styles)
  appearance    Json?    // { colors: { primary, secondary, ... }, typography, buttonStyle, cardStyle }
  
  // SEO & Meta
  seo           Json?    // { metaTitle, metaDescription, ogImage, keywords }
  
  // Business Info overrides (Social links, Maps, WhatsApp)
  businessInfo  Json?    
  
  // Sections Configuration
  // JSON array defining the sections, their order, visibility, and content data.
  // Example: [ { id: "1", type: "hero", isVisible: true, data: { title: "Welcome", ... } } ]
  sections      Json?

  // Page visibility toggles: { about?: boolean, shop?: boolean, contact?: boolean }. Missing key
  // or missing object means enabled (backward compatible with configs saved before this existed).
  pages         Json?

  visits        WebsiteVisit[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WebsiteVisit {
  id          String   @id @default(uuid())
  websiteId   String
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  path        String   // e.g., /site/{id}, /site/{id}/about
  referrer    String?
  pageTitle   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([websiteId, createdAt])
}

model ContactLead {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  subject     String?
  message     String
  source      String   @default("website") // website, menu, qr
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}

// A lead submitted through the CafeOS marketing site's own /contact form — deliberately separate
// from ContactLead above, which belongs to an individual tenant's cafe storefront (built via the
// Website Builder), not the SaaS's own site. No tenantId here on purpose: this is platform-level.
model MarketingLead {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
