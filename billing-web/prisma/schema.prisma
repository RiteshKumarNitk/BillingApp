generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String               @id @default(uuid())
  name               String
  domain             String               @unique
  dbConnectionString String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  status             String               @default("ACTIVE")
  address            String?
  contactPerson      String?
  email              String?              @unique
  gstin              String?
  phone              String?              @unique
  subscriptionPlan   String               @default("FREE")
  menuTheme          String?
  currency           String               @default("INR")
  logoUrl            String?
  timezone           String               @default("Asia/Kolkata")
  website            String?
  aadharCardUrl      String?
  version            Int                  @default(0)
  primaryColor       String?
  fontFamily         String?
  latitude           Float?
  longitude          Float?
  tagline            String?
  aboutText          String?
  coverImageUrl      String?
  businessHours      String?
  customers          Customer[]
  discounts          Discount[]
  employees          Employee[]
  expenses           Expense[]
  notifications      Notification[]
  orderRequests      OrderRequest[]
  products           Product[]
  roles              Role[]
  units              Unit[]
  shop               Shop?
  transactions       Transaction[]
  users              User[]
  subscriptions      TenantSubscription[]
  invoices           Invoice[]
  auditLogs          AuditLog[]
  websiteSettings    Website?
  websiteVisits      WebsiteVisit[]
  contactLeads       ContactLead[]
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, name])
}

// Tenant-managed master list of base units (PIECE, KG, LITRE, ...) offered as a dropdown when
// adding a product. Product.unit stays a plain string (not a FK) so deleting a Unit here never
// invalidates existing products — it just stops appearing as a pickable option going forward.
model Unit {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  password          String
  name              String
  role              String        @default("ADMIN")
  tenantId          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenantRoleId      String?
  phone             String?
  jobTitle          String?
  profilePictureUrl String?
  tokenVersion      Int           @default(0)
  transactions      Transaction[]
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantRole        Role?         @relation(fields: [tenantRoleId], references: [id])
  auditLogs         AuditLog[]
}

model Product {
  id                String            @id @default(uuid())
  name              String
  barcode           String?
  purchasePrice     Float             @default(0)
  mrp               Float             @default(0)
  salePrice         Float             @default(0)
  stock             Float             @default(0)
  expiryDate        DateTime?
  manufacturingDate DateTime?
  batchNumber       String?
  category          String?
  minStockThreshold Float             @default(10)
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  unit              String            @default("PIECE")
  allowDecimal      Boolean           @default(false)
  productType       String            @default("SIMPLE")
  description       String?
  imageUrl          String?
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches           ProductBatch[]
  serials           ProductSerial[]
  variants          ProductVariant[]
  transactionItems  TransactionItem[]

  @@unique([tenantId, barcode])
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String
  name          String
  barcode       String?
  purchasePrice Float
  mrp           Float
  salePrice     Float
  stock         Float   @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBatch {
  id                String    @id @default(uuid())
  productId         String
  batchNumber       String
  manufacturingDate DateTime?
  expiryDate        DateTime?
  stock             Float     @default(0)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSerial {
  id             String    @id @default(uuid())
  productId      String
  serialNumber   String
  status         String    @default("AVAILABLE")
  purchaseDate   DateTime?
  warrantyMonths Int?
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, serialNumber])
}

model CustomerAccount {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  tokenVersion  Int            @default(0)
  fcmToken      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customers     Customer[]
  orderRequests OrderRequest[]
  notifications Notification[]
}

model Customer {
  id                String           @id @default(uuid())
  name              String
  phone             String?
  email             String?
  address           String?
  loyaltyPoints     Int              @default(0)
  totalSpent        Float            @default(0)
  lastPurchaseDate  DateTime?
  createdDate       DateTime         @default(now())
  tenantId          String
  customerAccountId String?
  customerAccount   CustomerAccount? @relation(fields: [customerAccountId], references: [id])
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderRequests     OrderRequest[]
  notifications     Notification[]

  @@index([tenantId])
  @@index([customerAccountId])
}

model OrderRequest {
  id                String             @id @default(uuid())
  status            String             @default("PENDING")
  notes             String?
  totalAmount       Float              @default(0)
  taxAmount         Float              @default(0)
  netAmount         Float              @default(0)
  tenantId          String
  customerAccountId String
  customerId        String?
  transactionId     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  customerAccount   CustomerAccount    @relation(fields: [customerAccountId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             OrderRequestItem[]

  @@index([tenantId, status])
  @@index([customerAccountId])
}

model OrderRequestItem {
  id             String       @id @default(uuid())
  orderRequestId String
  productId      String
  name           String
  barcode        String?
  salePrice      Float
  quantity       Float
  itemTotal      Float
  orderRequest   OrderRequest @relation(fields: [orderRequestId], references: [id], onDelete: Cascade)
}

model Notification {
  id       String  @id @default(uuid())
  type     String  @default("ORDER_STATUS") // ORDER_STATUS, GENERAL, PROMOTION
  title    String
  message  String
  isRead   Boolean @default(false)
  orderId  String?
  metadata String? // JSON string for extra data

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerAccountId, isRead])
  @@index([tenantId, createdAt])
}

model Expense {
  id         String   @id @default(uuid())
  name       String
  category   String   @default("OTHER")
  amount     Float
  date       DateTime @default(now())
  notes      String?
  receiptUrl String?
  tenantId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
}

model Discount {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  code               String?   @unique
  discountPercentage Float
  applicableCategory String?
  minimumQuantity    Int       @default(1)
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean   @default(true)
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Employee {
  id                 String   @id @default(uuid())
  name               String
  email              String?
  phone              String?
  password           String?
  role               String   @default("CASHIER")
  isActive           Boolean  @default(true)
  monthlySalesTarget Float    @default(0)
  createdDate        DateTime @default(now())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Shop {
  id             String  @id @default(uuid())
  name           String?
  addressLine1   String?
  addressLine2   String?
  phoneNumber    String?
  upiId          String?
  footerText     String?
  defaultTaxRate Float   @default(0)
  tenantId       String  @unique
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                    String               @id @default(uuid())
  tenantId              String
  userId                String
  status                String               @default("COMPLETED")
  totalAmount           Float
  discount              Float                @default(0)
  netAmount             Float
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  amountReceived        Float?
  changeAmount          Float?
  customerId            String?
  customerName          String?
  customerPhone         String?
  discountType          String               @default("PERCENTAGE")
  notes                 String?
  paymentMethod         String?
  taxAmount             Float                @default(0)
  couponCode            String?
  couponDiscountAmount  Float                @default(0)
  loyaltyPointsRedeemed Int                  @default(0)
  loyaltyDiscountAmount Float                @default(0)
  loyaltyPointsEarned   Int                  @default(0)
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User                 @relation(fields: [userId], references: [id])
  items                 TransactionItem[]
  payments              TransactionPayment[]
}

model TransactionPayment {
  id            String      @id @default(uuid())
  transactionId String
  method        String
  amount        Float
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model TransactionItem {
  id             String      @id @default(uuid())
  transactionId  String
  productId      String
  name           String
  barcode        String
  purchasePrice  Float
  mrp            Float
  salePrice      Float
  quantity       Float
  itemTotal      Float
  discountAmount Float       @default(0)
  productType    String?
  batchId        String?
  serialId       String?
  variantId      String?
  product        Product     @relation(fields: [productId], references: [id])
  transaction    Transaction @relation(fields: [transactionId], references: [id])
}

model SubscriptionPlan {
  id              String               @id @default(uuid())
  name            String
  description     String?
  amount          Float
  currency        String               @default("INR")
  interval        String // "MONTHLY" or "YEARLY"
  razorpayPlanId  String?
  trialDays       Int                  @default(0)
  maxProducts     Int                  @default(-1)
  maxUsers        Int                  @default(-1)
  maxTransactions Int                  @default(-1)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  subscriptions   TenantSubscription[]
}

model TenantSubscription {
  id                     String    @id @default(uuid())
  tenantId               String
  planId                 String
  status                 String // "ACTIVE", "TRIAL", "CANCELLED", "PAST_DUE", "EXPIRED", "UNPAID"
  razorpaySubscriptionId String?   @unique
  startDate              DateTime  @default(now())
  endDate                DateTime
  trialStartDate         DateTime?
  trialEndDate           DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  canceledAt             DateTime?
  endedAt                DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
}

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  discountType   String // "PERCENTAGE" or "FIXED"
  discountValue  Float
  expiryDate     DateTime?
  maxRedemptions Int?
  redemptions    Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoices       Invoice[]
}

model Invoice {
  id                    String    @id @default(uuid())
  tenantId              String
  subscriptionId        String?
  invoiceNumber         String    @unique
  amount                Float
  discountAmount        Float     @default(0)
  netAmount             Float
  currency              String    @default("INR")
  status                String // "PAID", "PENDING", "FAILED"
  billingDate           DateTime  @default(now())
  dueDate               DateTime?
  paidAt                DateTime?
  razorpayPaymentId     String?
  razorpayOrderId       String?
  razorpaySignature     String?
  couponId              String?
  pdfUrl                String?
  failedPaymentAttempts Int       @default(0)
  nextRetryDate         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription TenantSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  coupon       Coupon?             @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Website {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  theme         String   @default("modern-restaurant")
  
  // Appearance (Colors, Fonts, Styles)
  appearance    Json?    // { colors: { primary, secondary, ... }, typography, buttonStyle, cardStyle }
  
  // SEO & Meta
  seo           Json?    // { metaTitle, metaDescription, ogImage, keywords }
  
  // Business Info overrides (Social links, Maps, WhatsApp)
  businessInfo  Json?    
  
  // Sections Configuration
  // JSON array defining the sections, their order, visibility, and content data.
  // Example: [ { id: "1", type: "hero", isVisible: true, data: { title: "Welcome", ... } } ]
  sections      Json?    

  visits        WebsiteVisit[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WebsiteVisit {
  id          String   @id @default(uuid())
  websiteId   String
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  path        String   // e.g., /site/{id}, /site/{id}/about
  referrer    String?
  pageTitle   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([websiteId, createdAt])
}

model ContactLead {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  subject     String?
  message     String
  source      String   @default("website") // website, menu, qr
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}
